    "NeedsPageOnboarding": {
        "FirstStep": {
            "description1": "דף זה מאפשר לנהל את הקטגוריות והמשימות עבור התוכנית שלכם. כאן תוכלו לגלות, לערוך ולהתאים אישית את הצרכים של המשפחות.",
            "description2": "כדי להתחיל, לחצו על יצירת תכנית:",
            "createTemplate": "יצירת תכנית"
        },
        "SecondStep": {
            "infoCard1": {
                "paragraph1": "התאימו את התוכנית אישית: ערכו את הקטגוריות כך שיתאימו למטרות התוכנית. לאחר מכן, הוסיפו משימות ספציפיות לכל קטגוריה על ידי בחירת קטגוריה ולחיצה על הוספת משימה' - כדי לקבוע אילו משימות יופיעו למשפחות באפליקציה.",
                "paragraph2": "על סמך הניסיון שלכם, תוכלו לבחור את המשימות השכיחות או החשובות ביותר עבור כל משפחה חדשה להתחיל איתן.",
                "paragraph3": "משפחות יוכלו לערוך או למחוק את המשימות הללו בהמשך אם הן אינן רלוונטיות עבורן.",
                "buttonPrompt": "עריכת קטגוריות"
            },
            "infoCard2": {
                "paragraph1": "לאחר מכן בחר מהרשימה או צור משימות. החליטו אילו משימות יהיו גלויות באפליקציה למשפחות לגילוי.",
                "paragraph2": "בנוסף, בהתבסס על הניסיון שלך, תוכל לבחור את המשימות החשובות או השכיחות ביותר עבור כל משפחה חדשה לעזור לה להתחיל להשתמש באפליקציה. למשפחות תהיה אפשרות לערוך או למחוק משימות אלו מאוחר יותר אם הן לא רלוונטיות.",
                "buttonPrompt": "השתמש בלחצן"
            }
        }
    },
