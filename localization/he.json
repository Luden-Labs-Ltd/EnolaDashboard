    "NeedsPageOnboarding": {
        "FirstStep": {
            "description1": "זה מאפשר לך לנהל את הקטגוריות והמשימות לתוכנית שלך. כאן תוכל לגלות, לערוך ולהתאים אישית את הצרכים עבור המשתמשים שלך.",
            "description2": "כדי להתחיל, צור את תבנית הקטגוריות הראשונית עבור התוכנית.",
            "createTemplate": "צור תבנית"
        },
        "SecondStep": {
            "infoCard1": {
                "paragraph1": "התחל על ידי בחירת קטגוריות. לאחר שנוצרו, לא ניתן למחוק או לשנות את שם הקטגוריות כדי להבטיח עקביות. אנו מספקים קבוצת קטגוריות ומשימות ראשונית לבחירה.",
                "paragraph2": "בעת הוספת קטגוריות, תצטרך לציין את השם, הסמל והצבע.",
                "buttonPrompt": "השתמש בלחצן"
            },
            "infoCard2": {
                "paragraph1": "לאחר מכן בחר מהרשימה או צור משימות. החליטו אילו משימות יהיו גלויות באפליקציה למשפחות לגילוי.",
                "paragraph2": "בנוסף, בהתבסס על הניסיון שלך, תוכל לבחור את המשימות החשובות או השכיחות ביותר עבור כל משפחה חדשה לעזור לה להתחיל להשתמש באפליקציה. למשפחות תהיה אפשרות לערוך או למחוק משימות אלו מאוחר יותר אם הן לא רלוונטיות.",
                "buttonPrompt": "השתמש בלחצן"
            }
        }
    },
